ENV=dev
LOG_LEVEL=INFO
PROJECT_NAME=auth-service
SERVICE_HOST=127.0.0.1
SERVICE_PORT=5602
SERVICE_RELOAD=true

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=
DB_NAME=auth_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

REDIS_URL=redis://localhost:6379/1

USER_SERVICE_URL=http://127.0.0.1:5601
INTERNAL_API_TOKEN=change-me-in-local-env
JWT_SECRET_KEY=change-me-in-local-env-with-at-least-32-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
